# ------------------------------------------------------------
#  Backend API alap URL
#  Formátum: https://<subdomain>.stud.vts.su.ac.rs/api/v1
#
#  A iskolai szerveren kiosztott aldomén alapján kell beállítani.
#  Jelenleg az alkalmazás kód is validálja, hogy az URL
#  a .stud.vts.su.ac.rs doménre mutasson (httpClient.js).
# ------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=https://undefined.stud.vts.su.ac.rs/api/v1
